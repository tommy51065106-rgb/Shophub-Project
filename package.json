{
  "name": "shophub-react",
  "version": "1.0.0",
  "description": "Shopping website built with React",
  "private": true,
  "dependencies": {
    "@stripe/react-stripe-js": "^6.2.0",
    "@stripe/stripe-js": "^9.3.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "sharp": "^0.32.4",
    "sqlite3": "^6.0.1",
    "stripe": "^22.1.0",
    "swiper": "^12.1.3"
  },
  "scripts": {
    "start": "npm --silent run kill:3000 && node server.js --open",
    "start:dev": "npm --silent run kill:3000 && react-scripts start",
    "start:clean": "npm run start",
    "build": "react-scripts build",
    "server": "npm run start",
    "kill:3000": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$ErrorActionPreference='SilentlyContinue'; $port=3000; $conns=Get-NetTCPConnection -LocalPort $port -State Listen; if(-not $conns){exit 0}; $ids=$conns | Select-Object -ExpandProperty OwningProcess -Unique; foreach($id in $ids){ Stop-Process -Id $id -Force }\"",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "devDependencies": {
    "react-scripts": "^5.0.1"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
